{
  "name": "eslint-plugin-readme",
  "version": "3.0.1",
  "description": "ESLint plugin providing custom rules for ReadMe's coding standards",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": "Jon Ursenbach <jon@ursenba.ch>",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git://github.com/readmeio/standards.git",
    "directory": "packages/eslint-plugin"
  },
  "bugs": {
    "url": "https://github.com/readmeio/standards/issues"
  },
  "homepage": "https://github.com/readmeio/standards#readme",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/",
    "docs/"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint .",
    "prepare": "npm run build",
    "test": "vitest run",
    "update:docs": "npm run build && eslint-doc-generator && npx prettier --write docs/rules/*.md *.md"
  },
  "peerDependencies": {
    "eslint": "^9.0.0"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.27.1",
    "@eslint/js": "^9.22.0",
    "@readme/eslint-config": "file:../eslint-config",
    "@typescript-eslint/parser": "^8.24.1",
    "eslint": "^9.22.0",
    "eslint-doc-generator": "^3.3.2",
    "typescript": "^5.8.3"
  }
}
